---
import { profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<!--<div class="border-t border-[var(&#45;&#45;primary)] mx-16 border-dashed py-8 max-w-[var(&#45;&#45;page-width)] flex flex-col items-center justify-center px-6">-->
<div class="transition border-t border-black/10 dark:border-white/15 my-10 border-dashed mx-32"></div>
<!--<div class="transition bg-[oklch(92%_0.01_var(&#45;&#45;hue))] dark:bg-black rounded-2xl py-8 mt-4 mb-8 flex flex-col items-center justify-center px-6">-->
<div class="transition border-dashed border-[oklch(85%_0.01_var(--hue))] dark:border-white/15 rounded-2xl mb-12 flex flex-col items-center justify-center px-6">
    <div class="footer-meta transition text-sm text-center">
        <span class="footer-force-black">&copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name}. All Rights Reserved. /</span>
        <span class="feed-link"><a class="transition link font-medium" target="_blank" href={url("rss.xml")}>RSS</a></span> /
        <a class="transition link font-medium" target="_blank" href={url("sitemap-index.xml")}>Sitemap</a> /
        <span class="beian"><a class="transition link font-medium" target="_blank" href="https://icp.gov.moe/?keyword=20260427">萌ICP备20260427号</a></span><br>
        <span class="footer-force-black">Powered by</span>
        <a class="transition link font-medium footer-link-astro" target="_blank" href="https://astro.build">Astro</a> &
        <a class="transition link font-medium footer-link-fuwari" target="_blank" href="https://github.com/saicaca/fuwari">Fuwari</a>
    </div>
</div>

<style>
  .footer-force-black {
    color: #6b7280 !important;
    text-shadow: none !important;
  }

  .footer-meta {
    color: var(--btn-content);
    color: color-mix(in oklab, var(--btn-content) 90%, black 10%);
    line-height: 1.75;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.28), 0 0 1px rgb(255 255 255 / 0.24);
  }

  :global(html.dark) .footer-meta {
    color: color-mix(in oklab, var(--btn-content) 92%, white 8%);
    text-shadow: 0 1px 3px rgb(0 0 0 / 0.6);
  }

  .footer-meta a {
    color: inherit;
    opacity: 0.92;
    text-decoration: none;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.26), 0 0 1px rgb(255 255 255 / 0.22);
  }

  .footer-meta a:hover {
    opacity: 1;
  }

  :global(html.dark) .footer-meta a {
    text-shadow: 0 1px 3px rgb(0 0 0 / 0.58);
  }
</style>
