---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);

const getNavItemClasses = (targetUrl: string, external = false) => {
	const classes = ["menu-item", "nav-link"];
	if (!external) {
		const normalizedUrl = targetUrl.endsWith("/") ? targetUrl : `${targetUrl}/`;
		if (normalizedUrl === "/") classes.push("menu-item-home");
		if (normalizedUrl === "/about/") classes.push("menu-item-about");
		if (normalizedUrl === "/archive/") classes.push("menu-item-archives");
	}
	return classes.join(" ");
};
---
<div id="navbar" class="z-50">
    <div class="absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)] transition"></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "card-base !overflow-visible max-w-[var(--page-width)] h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4"]}>
        <a href={url('/')} class:list={["btn-plain scale-animation rounded-lg h-[3.25rem] px-5 font-bold active:scale-95", getNavItemClasses("/")]} >
            <div class="nav-text flex flex-row text-[var(--primary)] items-center text-md">
                <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mb-1 mr-2" />
                {siteConfig.title}
            </div>
        </a>
        <div class="hidden md:flex">
            {links.map((l) => {
                return <a aria-label={l.name} href={l.external ? l.url : url(l.url)} target={l.external ? "_blank" : null}
                          class:list={["btn-plain scale-animation rounded-lg h-11 font-bold px-5 active:scale-95", getNavItemClasses(l.url, Boolean(l.external))]}
                >
                    <div class="nav-text flex items-center">
                        {l.name}
                        {l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-black/[0.2] dark:text-white/[0.2]"></Icon>}
                    </div>
                </a>;
            })}</div>
        <div class="flex">
            <!--<SearchPanel client:load>-->
            <Search client:only="svelte"></Search>
            <button aria-label="背景模式切换" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="background-mode-switch">
                <Icon name="material-symbols:landscape-rounded" class="text-[1.25rem]"></Icon>
            </button>
            <button aria-label="横幅启用开关" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="banner-enable-switch">
                <div id="banner-enable-icon-off" class="absolute transition-opacity duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="text-[1.25rem]" width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="currentColor" d="M5 21q-.825 0-1.412-.587T3 19v-6h2v6h6v2zm8 0v-2h6v-6h2v6q0 .825-.587 1.413T19 21zm-7-4l3-4l2.25 3l3-4L18 17zm-3-6V5q0-.825.588-1.412T5 3h6v2H5v6zm16 0V5h-6V3h6q.825 0 1.413.588T21 5v6zm-4.575-1.425Q14 9.15 14 8.5t.425-1.075T15.5 7t1.075.425T17 8.5t-.425 1.075T15.5 10t-1.075-.425"></path>
                    </svg>
                </div>
                <div id="banner-enable-icon-on" class="absolute transition-opacity duration-200 opacity-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="text-[1.25rem]" width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="currentColor" d="M5 21q-.825 0-1.412-.587T3 19V5q0-.825.588-1.412T5 3h14q.825 0 1.413.588T21 5v14q0 .825-.587 1.413T19 21zm0-2h14V5H5zm1-2h12l-3.75-5l-3 4L9 13zm-1 2V5z"></path>
                    </svg>
                </div>
            </button>
            {!siteConfig.themeColor.fixed && (
                    <button aria-label="Display Settings" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
            )}
            <LightDarkSwitch client:only="svelte"></LightDarkSwitch>
            <button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 md:!hidden" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        <NavMenuPanel links={links}></NavMenuPanel>
        <DisplaySettings client:only="svelte"></DisplaySettings>
    </div>
</div>

<script>
// @ts-nocheck
const DEV_EDITOR_KEY = "devEditorEnabled";
const DEV_EDITOR_CREDENTIAL_KEY = "devEditorCredential";
const DEV_EDITOR_LEGACY_CODE_KEY = "devEditorCode";
const DEV_EDITOR_AUTO_LOCK_AT_KEY = "devEditorAutoLockAt";
const DEV_EDITOR_SESSION_KEY = "devEditorSessionActive";
const DEV_EDITOR_SESSION_GRACE_UNTIL_KEY = "devEditorSessionGraceUntil";

function disableDevEditor() {
    localStorage.setItem(DEV_EDITOR_KEY, "false");
    localStorage.removeItem(DEV_EDITOR_CREDENTIAL_KEY);
    localStorage.removeItem(DEV_EDITOR_LEGACY_CODE_KEY);
    localStorage.removeItem(DEV_EDITOR_AUTO_LOCK_AT_KEY);
    localStorage.removeItem(DEV_EDITOR_SESSION_GRACE_UNTIL_KEY);
    try {
        sessionStorage.removeItem(DEV_EDITOR_SESSION_KEY);
    } catch (_error) {}
    window.dispatchEvent(new CustomEvent("developer-mode-change", { detail: false }));
}

function isDevEditorEnabled() {
    try {
        if (localStorage.getItem(DEV_EDITOR_KEY) !== "true") {
            return false;
        }

        if (sessionStorage.getItem(DEV_EDITOR_SESSION_KEY) !== "true") {
            disableDevEditor();
            return false;
        }

        const autoLockAtRaw = localStorage.getItem(DEV_EDITOR_AUTO_LOCK_AT_KEY);
        if (!autoLockAtRaw) {
            return true;
        }

        const autoLockAt = Number.parseInt(autoLockAtRaw, 10);
        if (!Number.isFinite(autoLockAt) || autoLockAt <= 0) {
            localStorage.removeItem(DEV_EDITOR_AUTO_LOCK_AT_KEY);
            return true;
        }

        if (Date.now() >= autoLockAt) {
            disableDevEditor();
            return false;
        }

        return true;
    } catch (_error) {
        return false;
    }
}

function applyDevEditorButtonVisibility() {
    const enabled = isDevEditorEnabled();
    const desktopLink = document.getElementById("dev-editor-link-desktop");
    const desktopDraftsLink = document.getElementById("dev-drafts-link-desktop");
    if (desktopLink) {
        desktopLink.classList.toggle("hidden", !enabled);
    }
    if (desktopDraftsLink) {
        desktopDraftsLink.classList.toggle("hidden", !enabled);
    }
}

function loadButtonScript() {
    let settingBtn = document.getElementById("display-settings-switch");
    if (settingBtn) {
        settingBtn.onclick = function () {
            let settingPanel = document.getElementById("display-setting");
            if (settingPanel) {
                settingPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    let menuBtn = document.getElementById("nav-menu-switch");
    if (menuBtn) {
        menuBtn.onclick = function () {
            let menuPanel = document.getElementById("nav-menu-panel");
            if (menuPanel) {
                menuPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    const backgroundModeBtn = document.getElementById("background-mode-switch");
    const bannerEnableBtn = document.getElementById("banner-enable-switch");
    const bannerEnableIconOff = document.getElementById("banner-enable-icon-off");
    const bannerEnableIconOn = document.getElementById("banner-enable-icon-on");

    const getCurrentDisplayMode = () => {
        const root = document.documentElement;
        if (root.classList.contains("background-fullheight")) return "full";
        const stored = localStorage.getItem("backgroundDisplayMode");
        return stored === "full" ? "full" : "banner";
    };
    const syncBackgroundModeBtn = (mode) => {
        if (!backgroundModeBtn) return;
        const isFull = mode === "full";
        backgroundModeBtn.classList.toggle("text-[var(--primary)]", isFull);
        backgroundModeBtn.setAttribute("aria-pressed", isFull ? "true" : "false");
    };
    const applyDisplayMode = (mode) => {
        const root = document.documentElement;
        const normalized = mode === "full" ? "full" : "banner";
        root.classList.add("background-mode-switching");
        void root.offsetHeight;
        requestAnimationFrame(() => {
            root.classList.toggle("background-fullheight", normalized === "full");
            root.style.setProperty("--background-height", normalized === "full" ? "100vh" : "66.67%");
            try { localStorage.setItem("backgroundDisplayMode", normalized); } catch {}
            window.dispatchEvent(new CustomEvent("background-display-mode-updated", { detail: { mode: normalized } }));
            syncBackgroundModeBtn(normalized);
        });
        window.setTimeout(() => {
            root.classList.remove("background-mode-switching");
        }, 460);
    };

    const getCurrentBannerEnabled = () => document.body.classList.contains("enable-banner");
    const syncBannerEnableBtn = (enabled) => {
        if (!bannerEnableBtn) return;
        bannerEnableBtn.classList.toggle("text-[var(--primary)]", enabled);
        bannerEnableBtn.setAttribute("aria-pressed", enabled ? "true" : "false");
        if (bannerEnableIconOff) {
            bannerEnableIconOff.classList.toggle("opacity-0", enabled);
        }
        if (bannerEnableIconOn) {
            bannerEnableIconOn.classList.toggle("opacity-0", !enabled);
        }
    };
    const applyBannerEnabled = (enabled) => {
        const root = document.documentElement;
        window.__bannerToggleInProgress = true;
        root.classList.add("background-mode-switching");
        void root.offsetHeight;
        requestAnimationFrame(() => {
            document.body.classList.toggle("enable-banner", enabled);
            try { localStorage.setItem("bannerEnabled", enabled ? "true" : "false"); } catch {}
            window.dispatchEvent(new CustomEvent("banner-enabled-updated", { detail: { enabled } }));
            syncBannerEnableBtn(enabled);
        });
        window.setTimeout(() => {
            root.classList.remove("background-mode-switching");
            window.__bannerToggleInProgress = false;
        }, 460);
    };

    if (backgroundModeBtn) {
        backgroundModeBtn.onclick = function () {
            const next = getCurrentDisplayMode() === "full" ? "banner" : "full";
            if (typeof window.__toggleBackgroundDisplayMode === "function") {
                window.__toggleBackgroundDisplayMode();
            } else {
                applyDisplayMode(next);
            }
        };
    }
    if (bannerEnableBtn) {
        bannerEnableBtn.onclick = function () {
            applyBannerEnabled(!getCurrentBannerEnabled());
        };
    }
    try {
        const storedBanner = localStorage.getItem("bannerEnabled");
        if (storedBanner === "true" || storedBanner === "false") {
            applyBannerEnabled(storedBanner === "true");
        } else {
            syncBannerEnableBtn(getCurrentBannerEnabled());
        }
        syncBackgroundModeBtn(getCurrentDisplayMode());
    } catch {}
    window.addEventListener("background-display-mode-updated", (event) => {
        const mode = event?.detail?.mode;
        if (typeof mode === "string") {
            syncBackgroundModeBtn(mode);
        }
    });
    window.addEventListener("banner-enabled-updated", (event) => {
        const enabled = event?.detail?.enabled;
        if (typeof enabled === "boolean") {
            syncBannerEnableBtn(enabled);
        }
    });

    applyDevEditorButtonVisibility();
}

loadButtonScript();
window.addEventListener("developer-mode-change", applyDevEditorButtonVisibility);
window.addEventListener("focus", applyDevEditorButtonVisibility);
document.addEventListener("visibilitychange", () => {
    if (!document.hidden) {
        applyDevEditorButtonVisibility();
    }
});
window.addEventListener("storage", (event) => {
    if (
        event.key === DEV_EDITOR_KEY ||
        event.key === DEV_EDITOR_AUTO_LOCK_AT_KEY
    ) {
        applyDevEditorButtonVisibility();
    }
});
</script>

<style>
:global(html.background-mode-switching #banner-wrapper),
:global(html.background-mode-switching #main-grid) {
    transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1), height 0.42s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
}

:global(html.background-mode-switching #main-panel-shell) {
    transition: top 0.42s cubic-bezier(0.22, 1, 0.36, 1);
}
</style>

{import.meta.env.PROD && <script is:inline define:vars={{scriptUrl: url('/pagefind/pagefind.js')}}>
async function loadPagefind() {
    try {
        const response = await fetch(scriptUrl, { method: 'HEAD' });
        if (!response.ok) {
            throw new Error(`Pagefind script not found: ${response.status}`);
        }

        const pagefind = await import(scriptUrl);

        await pagefind.options({
            excerptLength: 20,
            ranking: {
                termSimilarity: 0.6
            }
        });

        window.pagefind = pagefind;

        document.dispatchEvent(new CustomEvent('pagefindready'));
        console.log('Pagefind loaded and initialized successfully, event dispatched.');
    } catch (error) {
        console.error('Failed to load Pagefind:', error);
        window.pagefind = {
            search: () => Promise.resolve({ results: [] }),
            options: () => Promise.resolve(),
        };
        document.dispatchEvent(new CustomEvent('pagefindloaderror'));
        console.log('Pagefind load error, event dispatched.');
    }
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadPagefind);
} else {
    loadPagefind();
}
</script>}

