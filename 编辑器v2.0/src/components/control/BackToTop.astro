---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper">
    <div id="back-to-top-btn" class="back-to-top back-to-top-btn hide flex items-center rounded-3xl overflow-hidden transition" onclick="backToTop()">
        <button aria-label="Back to Top" class="back-to-top-inner h-[3.75rem] w-[3.75rem]">
            <Icon name="material-symbols:keyboard-arrow-up-rounded" class="mx-auto"></Icon>
        </button>
    </div>
</div>

<style lang="stylus">
.back-to-top-wrapper
    width: 3.75rem
    height: 3.75rem
    position: absolute
    right: 0
    top: 0
    pointer-events: none

.back-to-top-btn
    color: #67a8ff
    font-size: 2.25rem
    font-weight: bold
    border: none
    position: fixed
    right: 1.25rem
    bottom: 1.25rem
    padding-bottom: env(safe-area-inset-bottom)
    z-index: 60
    opacity: 1
    cursor: pointer
    transform: translateY(0) scale(1)
    pointer-events: auto
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.38)
    i
        font-size: 1.75rem
    &.hide
        transform: translateY(1.25rem) scale(0.92)
        opacity: 0
        pointer-events: none
    &:active:not(.hide)
      transform: translateY(0) scale(0.95)

.back-to-top-inner
    border: 0
    outline: none
    background: rgba(20, 20, 24, 0.86)
    -webkit-backdrop-filter: blur(8px)
    backdrop-filter: blur(8px)
    border-radius: 1.25rem
    display: flex
    align-items: center
    justify-content: center

</style>

<script is:raw is:inline>
function backToTop() {
    window.scroll({ top: 0, behavior: 'smooth' });
}
</script>
